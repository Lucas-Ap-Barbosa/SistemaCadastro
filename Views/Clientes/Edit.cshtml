@model SistemaCadastro.Models.Cliente

<h2>Editar Cliente</h2>

<form method="post">
    <input type="hidden" name="Id" value="@Model.Id" />

    Nome:<br />
    <input type="text" name="Nome" value="@Model.Nome" /><br />

    Email:<br />
    <input type="text" name="Email" value="@Model.Email" /><br />

    Telefone:<br />
    <input type="text" name="Telefone" value="@Model.Telefone" /><br /><br />

    <button type="submit">Salvar</button>
</form>

<br>
<a href="/Clientes">Voltar</a>